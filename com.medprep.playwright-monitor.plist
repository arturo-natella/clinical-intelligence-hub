<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.medprep.playwright-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Replaced by install_monitors.sh with actual paths -->
        <string>VENV_PYTHON</string>
        <string>-m</string>
        <string>src.monitoring.scheduler</string>
        <string>--mode</string>
        <string>playwright</string>
        <string>--data-dir</string>
        <string>DATA_DIR</string>
    </array>

    <key>WorkingDirectory</key>
    <string>PROJECT_DIR</string>

    <key>StartCalendarInterval</key>
    <dict>
        <!-- Run weekly on Sunday at 03:00 -->
        <key>Weekday</key>
        <integer>0</integer>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>LOG_DIR/playwright-monitor.log</string>
    <key>StandardErrorPath</key>
    <string>LOG_DIR/playwright-monitor-error.log</string>

    <key>RunAtLoad</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>PROJECT_DIR</string>
    </dict>
</dict>
</plist>
